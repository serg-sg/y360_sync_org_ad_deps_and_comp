token = ""
orgId = 123456

#   Адрес контролера домена для подключения по LDAP протоколу.
#    Eсли в AD несколько доменов, то обязательно DNS имя, в Linix должно быть настроено разрешение имен через локальный DNS.
#    Если домен один, можно указывать IP адрес.

LDAP_HOST = 'dc01.contoso.com'
# Порт глобального каталога (если в AD один домен, то можно использовать 389 порт)
#LDAP_PORT = 3269
LDAP_PORT = 636
# Флаг использования шифрованного подключения к LDAP
LDAP_USE_SSL = True
# Проверка сертификата контроллера домена (по умолчанию True)
LDAP_VALIDATE_CERT = True
# Путь к сертификату корневого центра сертификации
CA_ROOT_PATH = 'ca.cer'
# Учётная запись, от имени которой будет работать коннектор в формате netbios_domain_name\samaccountname или user@domain
LDAP_USER = 'ldap_connector@contoso.com'
LDAP_PASSWORD = 'password'
# Откуда в каталоге будет начинаться поиск пользователей, которые были мигрированы в Яндекс 360
LDAP_BASE_DN = 'OU=Office,DC=contoso,DC=com'

# Фильтры
# Фильтр поиска учётных записей пользователей, которые были мигрированы в Яндекс 360
LDAP_USER_SEARCH_FILTER = '(&(objectClass=user)(objectCategory=person)(mail=*@contoso.com)(!(userAccountControl:1.2.840.113556.1.4.803:=2))(memberOf=CN=Yandex360,OU=Groups,OU=Office,DC=contoso,DC=com))'
LDAP_DEPARTMENT_SEARCH_FILTER = '(objectClass=organizationalUnit)'

# Атрибуты
# Список атрибутов, которые возвращаются в результате поиска
ATTRIB_USER_LIST = 'distinguishedName,mail,displayName,company,department,objectGUID'
AD_DEPS_OUT_FILE = ""

# Сопоставление подразделений (fallback через запятую)
DEPARTMENT_NAME = 'description'
DEPARTMENT_DESCRIPTION = 'description'
DEPARTMENT_EXTERNALID = 'objectGUID'
DEPARTMENT_PARENT = 'msDS-parentdistname'

# Корень иерархии для Я360
DEPARTMENT_ROOT = 'OU=Office,DC=contoso,DC=com'

# Список почтовых доменов, которые считаются "разрешенными".
# Останутся только email адреса, принадлежащие этим доменам.
# Пример: DOMAINS_ALLOW = 'domain1.ru,domain2.ru'
# Если домен один, можно указать просто: DOMAINS_ALLOW = 'domain1.ru'
DOMAINS_ALLOW = 'contoso.com'

DRY_RUN = False
